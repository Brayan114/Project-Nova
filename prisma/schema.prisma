generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model User {
  id                String   @id @default(uuid())
  displayName       String
  relationshipScore Float    @default(0)
  interactionCount  Int      @default(0)
  preferenceVector  String   @default("{}") // JSON string
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  personalityState PersonalityState?
  emotionalState   EmotionalState?
  episodicMemories EpisodicMemory[]
  semanticMemories SemanticMemory[]
  sandboxAgents    SandboxAgent[]
  initiativeLog    InitiativeLog[]
  whatsappDrafts   WhatsAppDraft[]
}

model PersonalityState {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  traits          String   // JSON
  lastDriftUpdate DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EmotionalState {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  emotions  String   // JSON
  drives    String   // JSON
  updatedAt DateTime @updatedAt
}

model EpisodicMemory {
  id              String                      @id @default(uuid())
  userId          String
  user            User                        @relation(fields: [userId], references: [id])
  timestamp       DateTime                    @default(now())
  topic           String
  summary         String
  emotionalBefore String
  emotionalAfter  String
  importanceScore Float                       @default(0.5)
  tags            String                      @default("[]")
  embedding       Unsupported("vector(768)")?
}

model SemanticMemory {
  id             String                      @id @default(uuid())
  userId         String
  user           User                        @relation(fields: [userId], references: [id])
  fact           String
  relevanceScore Float                       @default(0.5)
  tags           String                      @default("[]")
  embedding       Unsupported("vector(768)")?
}

model SandboxAgent {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  personality String
  emotions    String
  drives      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InitiativeLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  delivered Boolean  @default(false)
  createdAt DateTime @default(now())
}

model WhatsAppDraft {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  contact   String
  incoming  String
  draft     String
  status    String   @default("pending") // pending, approved, rejected
  createdAt DateTime @default(now())
}
